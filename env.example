# Database
DATABASE_URL=postgresql+asyncpg://music_user:music_password@localhost:5432/music_analysis

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key

# Audio Processing
ESSENTIA_CONFIDENCE_THRESHOLD_BPM=0.7
ESSENTIA_CONFIDENCE_THRESHOLD_KEY=0.6
ESSENTIA_CONFIDENCE_THRESHOLD_STRUCTURE=0.5

# Storage
S3_BUCKET=music-analysis-platform
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4

# Debug
DEBUG=true
